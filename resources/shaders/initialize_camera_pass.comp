layout (local_size_x = 1, local_size_y = 1, local_size_z = 1) in;

#include<camera.glsl>
#include<counters.glsl>
#include<render_info.glsl>

void main(void)
{
    if (all(lessThan(gl_GlobalInvocationID, uvec3(1u))))
	{
		countersReset();
		cameraUpdate(renderInfoClusterSize(), renderInfoViewTransform(), renderInfoClipSpace(), renderInfoCullPlaneLimits());
	}
}
