sub-logger-distdir: FORCE
	@test -d logger/ || mkdir -p logger/
	cd logger/ && ( test -e Makefile || $(QMAKE) /home/moses/Simplex/logger/logger.pro -spec linux-g++-64 CONFIG+=debug CONFIG+=qml_debug -o Makefile ) && $(MAKE) -e -f Makefile distdir DISTDIR=$(DISTDIR)/logger

sub-renderer-distdir: FORCE
	@test -d renderer/ || mkdir -p renderer/
	cd renderer/ && ( test -e Makefile || $(QMAKE) /home/moses/Simplex/renderer/renderer.pro -spec linux-g++-64 CONFIG+=debug CONFIG+=qml_debug -o Makefile ) && $(MAKE) -e -f Makefile distdir DISTDIR=$(DISTDIR)/renderer

sub-starter-distdir: FORCE
	@test -d starter/ || mkdir -p starter/
	cd starter/ && ( test -e Makefile || $(QMAKE) /home/moses/Simplex/starter/starter.pro -spec linux-g++-64 CONFIG+=debug CONFIG+=qml_debug -o Makefile ) && $(MAKE) -e -f Makefile distdir DISTDIR=$(DISTDIR)/starter

