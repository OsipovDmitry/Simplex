sub-logger-check:
	@test -d logger/ || mkdir -p logger/
	cd logger/ && ( test -e Makefile || $(QMAKE) /home/moses/Simplex/logger/logger.pro -spec linux-g++-64 CONFIG+=debug CONFIG+=qml_debug -o Makefile ) && $(MAKE) -f Makefile check
sub-renderer-check:
	@test -d renderer/ || mkdir -p renderer/
	cd renderer/ && ( test -e Makefile || $(QMAKE) /home/moses/Simplex/renderer/renderer.pro -spec linux-g++-64 CONFIG+=debug CONFIG+=qml_debug -o Makefile ) && $(MAKE) -f Makefile check
