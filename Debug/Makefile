	cd starter/ && ( test -e Makefile || $(QMAKE) /home/moses/Simplex/starter/starter.pro -spec linux-g++-64 CONFIG+=debug CONFIG+=qml_debug -o Makefile ) && $(MAKE) -f Makefile check
